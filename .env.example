# =============================================================================
# Metatron Core — Environment Variables
#
#   cp .env.example .env
#
# Then scroll to the BOTTOM section ("SET THESE BEFORE FIRST RUN") and fill in
# the handful of values marked there. Everything above it has working defaults
# and does not need to be touched for a standard Docker install
# (docker-compose.full.yml).
#
# All vars mirror src/metatron/core/config.py (Settings) plus a few read directly
# via os.environ (MCP server, query-expansion LLM, admin cleanup, entity resolver).
# =============================================================================


# #############################################################################
# ZONE 1 — MANAGED ELSEWHERE / NOT USED IN THE DOCKER INSTALL
#
# Do NOT edit these for a standard docker-compose.full.yml deployment. They are
# either overridden by docker-compose (`environment:` wins over `env_file`),
# only used by other run modes, or legacy. Listed here for completeness.
# #############################################################################

# --- Database & service networking — SET BY docker-compose, .env is ignored ---
# Inside the Docker network the host is the service name; compose injects these.
# Editing them here has NO effect for docker-compose.full.yml.
POSTGRES_HOST=postgres               # compose -> postgres
POSTGRES_PORT=5432                    # compose -> 5432
POSTGRES_DB=metatron                  # compose -> metatron
POSTGRES_USER=metatron                # compose -> metatron
POSTGRES_PASSWORD=metatron_dev        # compose pins metatron_dev (internal DB)
QDRANT_HOST=qdrant                 # compose -> qdrant
QDRANT_HTTP_PORT=6333                 # container-internal port (leave default)
QDRANT_GRPC_PORT=6334                 # container-internal port (leave default)
QDRANT_API_KEY=                       # only for cloud / authenticated Qdrant
QDRANT_HTTPS=false
NEO4J_HOST=neo4j                  # compose -> neo4j
NEO4J_PORT=7687                       # container-internal port (leave default)
NEO4J_USER=                           # empty = no auth (compose NEO4J_AUTH=none)
NEO4J_PASSWORD=                       # Legacy MEMGRAPH_* aliases still accepted.
REDIS_HOST=redis                  # compose -> redis
REDIS_PORT=6379                       # compose -> 6379
REDIS_DB=0                            # compose -> 0
REDIS_PASSWORD=
SPLADE_SERVICE_URL=http://splade:8080                 # compose -> http://splade:8080
# OLLAMA_HOST: see ZONE 3 — bundled Ollama is forced to http://ollama:11434 by
# compose; only an EXTERNAL Ollama (separate deployment) makes use of an override.

# --- Auth (JWT) — off by default, not part of the basic install ---
AUTH_ENABLED=false                    # when true, JWT required on /api/v1/*
AUTH_PASSWORD=metatron                # password for /auth/login

# --- MCP standalone runner — only for `python -m metatron.mcp`, NOT the API mount ---
# The API serves /mcp over streamable-http regardless of these. (Auth key is in ZONE 3.)
METATRON_MCP_TRANSPORT=stdio          # stdio | streamable-http
METATRON_MCP_HOST=127.0.0.1
METATRON_MCP_PORT=8765

# --- OpenWebUI user-sync (bundled-host scenario only) ---
METATRON_OPENWEBUI_URL=
METATRON_OPENWEBUI_METATRON_URL=

# --- Separate Ollama LLM instance (advanced; chat LLM on a different Ollama) ---
# If OLLAMA_LLM_HOST is empty, the main Ollama is reused.
OLLAMA_LLM_HOST=
OLLAMA_LLM_PORT=11434
OLLAMA_LLM_MODEL=llama3
OLLAMA_NUM_CTX=32768                  # context window for Ollama chat
OLLAMA_REQUEST_TIMEOUT=               # seconds; empty = library default

# --- Freshness pipeline — NO worker ships with docker-compose.full.yml ---
# Master flag is off; the producer is a no-op. Leave disabled unless you also
# run `python -m metatron.memory.freshness` as a separate process.
METATRON_FRESHNESS_ENABLED=false
METATRON_FRESHNESS_POLL_SECONDS=2.0
METATRON_FRESHNESS_MAX_JOBS_PER_ITERATION=20
METATRON_FRESHNESS_LOCK_TTL_SECONDS=30
METATRON_FRESHNESS_STALE_AFTER_DAYS=30
METATRON_FRESHNESS_DECISION_CONFIDENCE_THRESHOLD=0.7
METATRON_FRESHNESS_LINKER_THRESHOLD=0.6
METATRON_FRESHNESS_RECONCILER_THRESHOLD=0.85
METATRON_FRESHNESS_BACKOFF_BASE_SECONDS=2.0
METATRON_FRESHNESS_BACKOFF_MAX_SECONDS=60.0
METATRON_FRESHNESS_MAX_CONSECUTIVE_ERRORS=10
METATRON_FRESHNESS_LLM_MODEL=qwen2.5-4b-instruct-q4
METATRON_FRESHNESS_LLM_PROVIDER=      # set with API_BASE_URL -> auto "custom"
METATRON_FRESHNESS_LLM_API_BASE_URL=
METATRON_FRESHNESS_LLM_API_KEY=
METATRON_FRESHNESS_HEARTBEAT_TTL_SECONDS=20
METATRON_FRESHNESS_RECLAIM_INTERVAL_ITERATIONS=30
METATRON_FRESHNESS_SCHEDULED_SCAN_ENABLED=true
METATRON_FRESHNESS_SCHEDULED_SCAN_INTERVAL_SECONDS=3600
METATRON_FRESHNESS_SCAN_BATCH_LIMIT=500
METATRON_FRESHNESS_DRAIN_LEGACY_AT_STARTUP=false
METATRON_FRESHNESS_KB_ENABLED=false
METATRON_FRESHNESS_KB_SEARCH_FILTER_ENABLED=false
METATRON_FRESHNESS_WEIGHT=0.0
METATRON_FRESHNESS_KB_STALE_AFTER_DAYS=90

# --- LLM generation telemetry (internal; fine-tuning bootstrap, MTRNIX-336) ---
METATRON_LLM_TELEMETRY_ENABLED=true   # master kill-switch; false -> no-op
METATRON_LLM_TELEMETRY_RETENTION_DAYS=0
METATRON_LLM_TELEMETRY_OPT_OUT_CACHE_TTL_SECONDS=60

# --- Ops / dev tooling ---
ALLOW_CLEANUP=false                   # gate destructive /api/v1/admin/cleanup*
BENCHMARKER_EMBEDDING_PROXY_URL=http://localhost:8001   # dev eval tool only

# --- Legacy connector / channel env vars (transitional) ---
# Connector creds (CONFLUENCE_*, JIRA_*, NOTION_TOKEN, GITHUB_TOKEN, GDRIVE_*,
# SLACK_HISTORY_*) and channel tokens (TELEGRAM_BOT_TOKEN, DISCORD_TOKEN,
# SLACK_BOT_TOKEN) are now managed via the Connections API/UI and stored
# Fernet-encrypted in PostgreSQL. `storage/migrate_env_connections.py` reads
# them once at startup for a one-time DB migration, then they can be removed.
# Channels (Telegram/Discord/Slack) are scheduled for removal — see docs/LEGACY.md.


# #############################################################################
# ZONE 2 — DEFAULTS (safe to leave as-is)
#
# Sensible defaults that match the codebase. You normally do not change these.
# #############################################################################

# --- Application ---
METATRON_ENV=development              # development | staging | production
METATRON_HOST=0.0.0.0                 # bind address (0.0.0.0 = all interfaces)
METATRON_PORT=8000                    # in-container API port (host maps to :8001)
METATRON_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR | CRITICAL
CORS_ORIGINS=*                        # comma-separated list, or * for all

# --- File storage & workspace defaults ---
FILE_STORE_PATH=./data/files
DEFAULT_WORKSPACE_ID=MTRNIX
DEFAULT_WORKSPACE_NAME=MTRNIX
WORKSPACE_PERSISTENCE=neo4j           # neo4j | postgres

# --- Model defaults (override only if you need a specific model) ---
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text   # 768-dim; always used for embeddings
# DeepSeek active models: deepseek-v4-pro (capable) / deepseek-v4-flash (fast).
# deepseek-chat / deepseek-reasoner are DEPRECATED (retire 2026-07-24) — avoid.
DEEPSEEK_MODEL=deepseek-v4-pro        # HEAVY tier (final RAG answer)
DEEPSEEK_MODEL_FAST=deepseek-v4-flash # FAST tier (resolve/expand/classify/NER/slots)
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct
OPENROUTER_APP_NAME=metatron
OPENROUTER_SITE_URL=
CUSTOM_LLM_MODEL=default
METATRON_AUX_LLM_TIMEOUT=10           # aux LLM (expansion/classifier) timeout, sec
LLM_FALLBACK_PROVIDER=                # fallback provider if primary fails

# --- OpenAI-compatible API (OpenWebUI / LibreChat / OAI clients) ---
METATRON_OPENAI_COMPAT_ENABLED=true   # enable /v1/models and /v1/chat/completions

# --- Search pipeline: feature toggles ---
QUERY_EXPANSION_ENABLED=true          # LLM-based query expansion
RERANKER_ENABLED=true                 # bge-reranker-v2-m3 cross-encoder
QUERY_CLASSIFIER_ENABLED=true         # hybrid rule+LLM query classifier
HYDE_ENABLED=false                    # HyDE for short/vague queries
ADAPTIVE_RRF_ENABLED=false            # adaptive RRF fusion (regresses metrics, off)
ENABLE_SEMANTIC_MATCHING=true         # semantic entity matching in resolver
METATRON_HIERARCHICAL_CHUNKING_ENABLED=true

# --- Search pipeline: MTRNIX-397 retrieval fixes (defaults = today's behaviour) ---
METATRON_RETRIEVAL_SCORING_NORMALIZE_ACTIVE_ONLY=true   # S1 (safe on)
METATRON_RETRIEVAL_SLOT_EXTRACTION_ENABLED=false        # B0 (regex-only when off)
METATRON_RETRIEVAL_SLOT_EXTRACTION_TIMEOUT=6
METATRON_RETRIEVAL_GRAPH_NER_ENABLED=false              # G1
METATRON_RETRIEVAL_FUTURE_DATE_FALLBACK_ENABLED=false   # M6

# --- Search pipeline: HyDE tuning ---
HYDE_MAX_WORDS=4
HYDE_TIMEOUT=8

# --- Search pipeline: budget & recall ---
SEARCH_MAX_TOTAL_CHARS=40000          # max context chars sent to LLM
SEARCH_MAX_FRAGMENT_CHARS=8000        # max chars per single fragment
SEARCH_POOL_MULTIPLIER=3              # fetch N× more results than needed
SEARCH_POOL_MIN=15                    # minimum candidate pool size
RECALL_TOP_N_DENSE=30
RECALL_TOP_N_EXACT=10
RECALL_TOP_N_METADATA=10
RECALL_TOP_N_GRAPH=5
RECALL_GRAPH_MAX_DEPTH=2
RRF_K_LOW=20
RRF_K_HIGH=80
RRF_OVERLAP_THRESHOLD_LOW=0.2
RRF_OVERLAP_THRESHOLD_HIGH=0.7
LLM_CONTEXT_MAX_TOKENS=10000
LLM_ANSWER_RESERVE_TOKENS=1500

# --- Search pipeline: sparse retrieval ---
SPLADE_ENABLED=true                   # SPLADE replaces BM25; BM25 is the fallback
SPLADE_MODEL=naver/splade-cocondenser-ensembledistil
SPLADE_MAX_LENGTH=256
BM25_VOCAB_SIZE=30000                 # BM25 fallback vocabulary size

# --- Search pipeline: embedding cache & ingest concurrency ---
EMBEDDING_CACHE_TTL=3600              # seconds
EMBEDDING_CACHE_MAXSIZE=2048
INGEST_EMBED_CONCURRENCY=2            # caps ingest-path embedding calls

# --- Graph extraction ---
GRAPH_EXTRACTION_ENABLED=true
GRAPH_EXTRACTION_WORKERS=1            # raise (e.g. 4) to speed up graph phase
GRAPH_EXTRACTION_MIN_CHARS=100

# --- Agent memory (WS1) ---
METATRON_MEMORY_SESSION_TTL=14400     # session memory TTL (seconds; 4h)
METATRON_MEMORY_SEARCH_DENSE_WEIGHT=0.6
METATRON_MEMORY_SEARCH_GRAPH_WEIGHT=0.3
METATRON_MEMORY_SEARCH_SESSION_WEIGHT=0.1
METATRON_MEMORY_SEARCH_TOP_K_MULTIPLIER=3
METATRON_SEARCH_FAST_TOP_K=10
METATRON_SEARCH_FAST_INCLUDE_METADATA=true


# #############################################################################
# ZONE 3 — SET THESE BEFORE FIRST RUN
#
# The only values you actually need to provide. Fill them in after copying
# this file to .env.
# #############################################################################

# --- 1) LLM provider + credentials -----------------------------------------
# Pick ONE provider. Embeddings always run on the bundled Ollama regardless.
# NOTE: docker-compose.full.yml must NOT hard-pin `LLM_PROVIDER: ollama` in its
# `environment:` block, or this value is ignored. Use ${LLM_PROVIDER:-ollama}.
#
# ollama (built-in, works out of the box):
#   LLM_PROVIDER=ollama
#
# deepseek:
#   LLM_PROVIDER=deepseek
#   DEEPSEEK_API_KEY=sk-your-deepseek-key
#
# openrouter:
#   LLM_PROVIDER=openrouter
#   OPENROUTER_API_KEY=sk-or-your-openrouter-key
#
# custom (any OpenAI-compatible endpoint — vLLM, LocalAI, ...):
#   LLM_PROVIDER=custom
#   CUSTOM_LLM_URL=https://your-llm-endpoint/v1
#   CUSTOM_LLM_API_KEY=your-key
#
# ollama on an EXTERNAL host (NOT the bundled one — requires removing the
# OLLAMA_HOST override in docker-compose for the API service):
#   LLM_PROVIDER=ollama
#   OLLAMA_HOST=http://your-ollama-host:11434
#
LLM_PROVIDER=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_LLM_URL=                       # e.g. http://localhost:8080/v1
CUSTOM_LLM_API_KEY=
OLLAMA_HOST=http://localhost:11434/    # bundled stack overrides this to http://ollama:11434

# --- 2) MCP auth token ------------------------------------------------------
# Bearer token for the /mcp endpoint (Hermes / Cursor / Claude Desktop / OpenClaw).
# A token YOU create — any strong string. Generate one:  openssl rand -hex 32
# Empty = MCP accepts connections with no auth.
METATRON_MCP_API_KEY=8uY2nM5qL0pO3iU7yT4rE6wQ9zA1sD4fG7hJ9kL2zX5cV8bN=

# --- 3) Secrets (generate; required for a real deployment) ------------------
# Encryption key for stored connector credentials (Fernet). Required before you
# add any connector. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=BjVJBL7mB7oQNaFw5KLR5B4cn9iZYIyMiy5TO3S_qMs=
# App secret (JWT signing). Change from the placeholder if you enable AUTH_ENABLED.
METATRON_SECRET_KEY=develop-secret-key-change-in-prod

# --- 4) Optional: OpenAI-compat static key (for Open WebUI / OAI clients) ---
# Leave empty to rely on per-user mtk_* keys. If set, Open WebUI uses it.
METATRON_OPENAI_COMPAT_KEY=metatron-test-key
