# =============================================================================
# Metatron Core — Environment Variables
# Copy to .env and adjust values for your environment.
# =============================================================================

# --- Application ---
METATRON_ENV=development          # development | staging | production
METATRON_PORT=8000                # HTTP port for the API server
METATRON_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
METATRON_SECRET_KEY=change-me-in-production  # JWT signing + Fernet derivation

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=metatron
POSTGRES_USER=metatron
POSTGRES_PASSWORD=metatron_dev

# --- Qdrant (vector store) ---
QDRANT_HOST=localhost
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Memgraph (knowledge graph) ---
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USER=              # empty = no auth (default for dev)
MEMGRAPH_PASSWORD=

# --- Ollama (LLM + embeddings) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b       # model for routing and chat
OLLAMA_EMBED_MODEL=nomic-embed-text  # model for embeddings

# --- Encryption ---
FERNET_KEY=                  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# --- Connectors (optional, configure as needed) ---
# CONFLUENCE_BASE_URL=https://your-org.atlassian.net/wiki
# CONFLUENCE_EMAIL=
# CONFLUENCE_API_TOKEN=

# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=
# JIRA_API_TOKEN=

# NOTION_API_TOKEN=

# GITHUB_TOKEN=
# GITHUB_ORG=

# GDRIVE_CREDENTIALS_JSON=       # path to service account JSON

# --- Channels (optional, configure as needed) ---
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=                # for socket mode
# SLACK_SIGNING_SECRET=

# --- File storage ---
FILE_STORE_PATH=./data/files      # local path for uploaded files
