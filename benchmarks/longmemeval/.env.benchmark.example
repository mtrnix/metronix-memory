# LongMemEval benchmark environment
# Copy to .env.benchmark and edit before running. Full reference:
# docs/benchmarks/longmemeval.md#environment-variables
#
# Location: benchmarks/longmemeval/.env.benchmark
# (NOT the repo-root .env used by Docker / install.sh)

# --- Metronix (memory backend) ---
# REQUIRED: Bearer token for /mcp (copy from repo-root .env created by install.sh)
METRONIX_MCP_API_KEY=
# MCP endpoint: default http://localhost:8000/mcp
# = metronix-full-api container (metronix-core in docker-compose.full.yml), port 8000, path /mcp
# From another container on the same Docker network: http://metronix-core:8000/mcp
METRONIX_MCP_URL=http://localhost:8000/mcp
# REST API for preflight/workspace: same container, port 8000, no /mcp suffix
METRONIX_API_URL=http://localhost:8000
# Isolated workspace for benchmark data (created by setup.sh / preflight)
LME_WORKSPACE_ID=MABENCH

# --- Chat LLM (answer generation) ---
# REQUIRED: API key from your LLM provider (OpenAI, DeepSeek, OpenRouter, etc.)
LME_CHAT_API_KEY=
# OpenAI-compatible base URL for chat completions
LME_CHAT_BASE_URL=https://api.openai.com/v1
# Model name for generating benchmark answers (recommended: gpt-4o-mini)
LME_CHAT_MODEL=gpt-4o-mini

# --- Judge LLM (evaluation step) ---
# API key (sk-...). NOT the model name. Leave empty to reuse LME_CHAT_API_KEY.
LME_JUDGE_API_KEY=
# OpenAI-compatible base URL for the judge model
LME_JUDGE_BASE_URL=https://api.openai.com/v1
# Judge model (recommended: gpt-4o for paper-comparable scores)
LME_JUDGE_MODEL=gpt-4o

# --- Retrieval tuning ---
# Number of memory hits injected into the answer prompt
LME_RETRIEVE_TOP_K=10

# --- Legacy fallback (optional) ---
# Used only when LME_CHAT_API_KEY / LME_JUDGE_API_KEY are not set
# OPENAI_API_KEY=
